# Supabase (Project Settings → API). Copy to .env.local — never commit secrets.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Cloudflare R2 (Clips video only). R2 → Overview → Account ID; create bucket + API token with Object Read & Write.
# Server-only — do not use NEXT_PUBLIC_* for these.
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=YOUR_BUCKET_NAME

# Resend (transactional: .edu verification, password reset, notifications). Server-only.
RESEND_API_KEY=re_YOUR_API_KEY

# Optional until sending mail — verified-domain sender (Resend → Domains). Used in P1-006+.
# RESEND_FROM=Vibe <noreply@updates.yourdomain.com>
