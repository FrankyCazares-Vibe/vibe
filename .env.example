# Supabase (Project Settings → API). Copy to .env.local — never commit secrets.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Server-only — Auth admin (password reset links), school email updates. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY

# Public site URL for email links (production). Fallback: VERCEL_URL on Vercel, http://localhost:3000 locally.
# Use your canonical origin (e.g. https://www.connectvibe.app). Sign-up confirmation links use this so they
# match Supabase Auth → URL Configuration. Add both to Redirect URLs:
#   https://www.connectvibe.app/auth/callback**
#   http://localhost:3000/auth/callback**
# Set Site URL to the same canonical origin.
# Must be a real HTTPS URL (e.g. https://www.connectvibe.app). Do not set this to the text NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app

# HMAC secret for .edu verification tokens (min 16 chars, random).
SCHOOL_EMAIL_VERIFY_SECRET=generate_a_long_random_string_here

# Cloudflare R2 (Clips video only). R2 → Overview → Account ID; create bucket + API token with Object Read & Write.
# Server-only — do not use NEXT_PUBLIC_* for these.
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=YOUR_BUCKET_NAME

# Resend (transactional: .edu verification, password reset, notifications). Server-only.
RESEND_API_KEY=re_YOUR_API_KEY

# Verified-domain sender (Resend → Domains). Required to send password reset + .edu verification.
RESEND_FROM=Vibe <noreply@updates.yourdomain.com>

# Sentry (Settings → Projects → Client Keys → DSN). Needed on client + server; use NEXT_PUBLIC_* as per Sentry Next.js SDK.
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# Optional — CI / production builds: upload source maps (never commit the token).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=vibe
